// Replace ONLY the click handler + the function header below

// ✅ Click handler (balanced braces)
$('#loginBtn').onclick = async () => {
  try {
    setApi($('#api').value.trim());
    const j = await api('/auth/login', {
      method: 'POST',
      body: JSON.stringify({
        email: $('#email').value.trim(),
        password: $('#password').value
      })
    });
    setToken(j.token);

    await ensureMe();
    renderNav();
    showMsg('Signed in.', 'ok');

    // bounce back to TAP if we came from one
    try {
      const ret = localStorage.getItem('ernos_return_to');
      if (ret) {
        localStorage.removeItem('ernos_return_to');
        location.href = ret;
        return;
      }
    } catch (e) {
      /* ignore */
    }

    navTo('#dashboard');
  } catch (e) {
    showMsg(e.message || String(e), 'err');
  }
}; // <— this semicolon closes the assignment. There should be NOTHING after this except code (no extra }).

