  <style>
    /* === Responsive polish (mobile-first) === */
    html, body { font-size: 16px; line-height: 1.45; }

    /* Images/logos scale nicely */
    img { max-width: 100%; height: auto; }

    /* Header with standard logo */
    header.skin-header { padding: 10px 14px; background:#4E6E81; border-bottom:1px solid #3E5967; display:flex; gap:10px; align-items:center; }
    header.skin-header img { height: 48px; display:block; }
    @media (min-width:761px){ header.skin-header img{ height:54px } }

    /* Sidebar */
    .sidebar{ position:fixed; inset:0 auto 0 0; width:270px; background:#fff; border-right:1px solid var(--border); display:flex; flex-direction:column; padding:16px; gap:12px; transform:translateX(-100%); transition:transform .2s ease; z-index:1000; }
    .sidebar.open{ transform:none; }
    .sidebar .brand{ display:flex; align-items:center; justify-content:center; padding: 14px 12px; }
    .sidebar .brand img{ height: 96px; width:auto; }
    @media (min-width: 900px){ .sidebar{ transform:none } .sidebar .brand img{ height: 120px } }

    .main{ min-height:100dvh; display:flex; flex-direction:column; }
    @media (min-width: 900px){ .main{ margin-left:270px } }

    .topbar{ position:sticky; top:0; z-index:900; display:flex; align-items:center; justify-content:space-between; gap:12px; padding:10px 14px; background:linear-gradient(180deg, rgba(255,255,255,.92), rgba(255,255,255,.86)); border-bottom:1px solid var(--border); }
    #menuBtn{ display:inline-flex }
    @media (min-width:900px){ #menuBtn{ display:none } }

    #view{ padding:14px; }

    /* Grid helpers: become responsive by default */
    .grid{ display:grid; gap:12px }
    .grid.cols-2{ grid-template-columns: repeat(auto-fit, minmax(220px,1fr)); }
    .grid.cols-3{ grid-template-columns: repeat(auto-fit, minmax(220px,1fr)); }

    /* Tables: keep horizontal scroll on small screens */
    .table-wrap{ overflow:auto; -webkit-overflow-scrolling: touch; }
    .table{ width:100%; border-collapse: collapse; border-spacing:0; font-size:14px; }
    @media (min-width:900px){ .table{ font-size:16px } }

    /* Cards/buttons text a tad smaller on phones */
    .card, .kv, .alert, .table, .btn, .topbar { font-size: 16px; }
    @media (min-width:900px){ .card, .kv, .alert, .table, .btn, .topbar { font-size: 18px } }

    .btn{ display:inline-flex; align-items:center; gap:8px; background:var(--accent); border:0; color:#fff; font-weight:700; border-radius:10px; padding:10px 12px; cursor:pointer; text-decoration:none; }
    .btn.ghost{ background:transparent; border:1px solid var(--border); color:var(--text) }
    .btn.small{ padding:6px 10px; font-weight:600 }

    /* No-line tables (kept) */
    .table, .table *, .kv, .kv *, .alert, .alert *, .empty { border:0 !important; outline:0 !important; box-shadow:none !important; text-decoration:none !important; background-image:none !important; }
    .table th{ text-transform:uppercase; letter-spacing:.06em; font-weight:800; color:var(--muted); padding:8px 12px }
    .table td{ padding:10px 12px }

    /* Focus visible */
    :where(a,button,[tabindex]):focus-visible{ outline:2px solid var(--accent) !important; outline-offset:2px }

    /* Alerts & tags */
    .alert{ padding:10px 12px; border:1px solid var(--border); background:#fff; color:var(--text); border-radius:10px }
    .alert.ok{ background:#E9F5EF; border-color:#CFE8DB; color:#1D5C45 }
    .alert.warn{ background:#FFF5E6; border-color:#F3E0BD; color:#7A5A05 }
    .alert.err{ background:#FDEEEE; border-color:#F1C9C9; color:#7A2A2A }

    .card{ background:#fff; border:1px solid var(--border); border-radius:16px; box-shadow:var(--shadow); padding:16px; margin-bottom:16px }
    .title, h2{ font-size:18px; margin:0 0 6px 0 }

    .empty{ border:1px dashed var(--border); border-radius:14px; padding:16px; text-align:center; color:var(--muted); background:#fff }

    /* Sidebar light palette that matches your logo */
    .sidebar{ background:var(--sidebar-gray); border-right:1px solid var(--sidebar-gray-darker); color:var(--sidebar-link) }
    .sidebar .brand{ color: var(--sidebar-link-muted) }
    .sidebar nav a{ display:block; padding:10px 12px; border-radius:10px; color:var(--sidebar-link); text-decoration:none; border:1px solid transparent }
    .sidebar nav a.active, .sidebar nav a:hover{ background: rgba(255,255,255,.10); border-color: rgba(255,255,255,.22) }
    .sidebar .sidebar-footer{ margin-top:auto }
    .sidebar .sidebar-footer .btn, .sidebar .sidebar-footer .btn.ghost{ border:1px solid rgba(255,255,255,.35); color:#fff; background:transparent }

    /* Prevent body scroll when sidebar open on mobile */
    body.nav-open{ overflow:hidden }
